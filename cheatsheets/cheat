#!/usr/bin/env bash
# cheat: show a cheatsheet; fuzzy-search with query args
# When launched without a TTY (e.g. from KRunner), re-exec inside a terminal

if [ ! -t 0 ]; then
    export CHEAT_HOLD=1
    if command -v xdg-terminal-exec >/dev/null 2>&1; then
        exec xdg-terminal-exec "$0" "$@"
    fi
    exec konsole -e "$0" "$@"
fi

data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
dir="$data_home/cheatsheets"

if [ ! -d "$dir" ]; then
    echo "cheat: $dir nicht gefunden" >&2
    exit 1
fi

# Debian/Ubuntu: bat binary heißt batcat
bat=bat
if ! command -v bat >/dev/null 2>&1 && command -v batcat >/dev/null 2>&1; then
    bat=batcat
fi

sheets=$(command ls "$dir")

# If a sheet-name query is given but matches no sheet, drop it and open the
# full picker as if no argument had been passed.
if [ -n "${1:-}" ] && ! printf '%s\n' "$sheets" | fzf --filter "$1" | grep -q .; then
    set --
fi

file=$(printf '%s\n' "$sheets" | fzf \
    --query "${1:-}" \
    --select-1 --exit-0 \
    --preview "$bat --color=always --style=plain '$dir'/{}" \
    --preview-window 'right,70%')

[ -n "$file" ] || exit

if [ "$#" -lt 2 ]; then
    "$bat" --style=plain "$dir/$file"
    exit
fi

pick=$(grep -n . "$dir/$file" | fzf \
    --query "${*:2}" \
    --delimiter : \
    --with-nth 2.. \
    --layout reverse \
    --preview "$bat --color=always --style=plain --highlight-line {1} '$dir/$file'" \
    --preview-window "right,70%,+{1}-/2")

if [ -n "$pick" ]; then
    line=${pick#*:}
    printf '%s\n' "$line"
    # copy to clipboard (Wayland/X11, best effort)
    if command -v wl-copy >/dev/null 2>&1; then
        printf '%s' "$line" | wl-copy
    elif command -v xclip >/dev/null 2>&1; then
        printf '%s' "$line" | xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then
        printf '%s' "$line" | xsel --clipboard --input
    fi
    # keep the terminal open when launched from KRunner
    if [ -n "${CHEAT_HOLD:-}" ]; then
        read -rsn 1 -p 'Kopiert – beliebige Taste zum Schließen '
    fi
fi
